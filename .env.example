# Copy to .env and fill in. .env is gitignored.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local OpenAI-compatible inference server (vLLM, LM Studio, llama.cpp, ...).
LOCAL_BASE_URL=http://localhost:1234/v1

# Optional: force prompted tool-calling for the local provider regardless of
# the model name. Values: auto (default — Gemma triggers prompted, others
# native) | prompted | native.
# LOCAL_TOOL_PROMPTING=auto
